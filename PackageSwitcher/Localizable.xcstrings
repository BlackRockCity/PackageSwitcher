    "about.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A native macOS utility for switching your .bash_profile between Homebrew and MacPorts."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用于在 Homebrew 和 MacPorts 之间切换 .bash_profile 的原生 macOS 工具。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una utilidad nativa de macOS para cambiar .bash_profile entre Homebrew y MacPorts."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un utilitaire macOS natif pour basculer .bash_profile entre Homebrew et MacPorts."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein natives macOS-Dienstprogramm zum Umschalten der .bash_profile zwischen Homebrew und MacPorts."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": ".bash_profile を Homebrew と MacPorts の間で切り替えるネイティブ macOS ユーティリティです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": ".bash_profile을 Homebrew와 MacPorts 간에 전환하는 기본 macOS 유틸리티입니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Um utilitário nativo para macOS que alterna a .bash_profile entre Homebrew e MacPorts."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أداة macOS أصلية للتبديل في .bash_profile بين Homebrew وMacPorts."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": ".bash_profile को Homebrew और MacPorts के बीच बदलने वाली एक मूल macOS उपयोगिता।"
          }
        }
      }
    },
