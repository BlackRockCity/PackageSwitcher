    "app.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Switch the package manager used by new Terminal sessions."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "切换新终端会话使用的软件包管理器。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambia el gestor de paquetes usado por las nuevas sesiones de Terminal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Change le gestionnaire de paquets utilisé par les nouvelles sessions Terminal."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wechselt den Paketmanager für neue Terminal-Sitzungen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しいターミナルセッションで使用するパッケージマネージャを切り替えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "새 터미널 세션에서 사용할 패키지 관리자를 전환합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Alterna o gestor de pacotes usado por novas sessões do Terminal."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بدّل مدير الحزم المستخدم في جلسات الطرفية الجديدة."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नए टर्मिनल सत्रों में उपयोग होने वाला पैकेज मैनेजर बदलें।"
          }
        }
      }
    },
    "app.profile_helper": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PackageSwitcher edits the Homebrew and MacPorts lines in your existing .bash_profile."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PackageSwitcher 会编辑现有 .bash_profile 中的 Homebrew 和 MacPorts 行。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "PackageSwitcher edita las líneas de Homebrew y MacPorts en tu .bash_profile existente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "PackageSwitcher modifie les lignes Homebrew et MacPorts de votre .bash_profile existant."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "PackageSwitcher bearbeitet die Homebrew- und MacPorts-Zeilen in der vorhandenen .bash_profile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PackageSwitcher は既存の .bash_profile 内の Homebrew と MacPorts の行を編集します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "PackageSwitcher는 기존 .bash_profile의 Homebrew 및 MacPorts 줄을 편집합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O PackageSwitcher edita as linhas do Homebrew e MacPorts no .bash_profile existente."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يعدّل PackageSwitcher أسطر Homebrew وMacPorts في ملف .bash_profile الحالي."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "PackageSwitcher मौजूदा .bash_profile में Homebrew और MacPorts की पंक्तियाँ संपादित करता है।"
          }
        }
      }
    },
